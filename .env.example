# ============================================================
# LMS B2B diBimbing - Konfigurasi GraphQL (CONTOH)
# Salin ke `.env` lalu isi nilai aslinya. JANGAN commit `.env`.
# ============================================================

# --- Endpoint ---
BASE_URL: https://lmsb2b.do.dibimbing.id/graphql

# --- Lapis 1: HTTP Basic Auth (akses server / gateway) ---
USERNAME: b2bserveruser
PASSWORD: <isi-password-basic-auth>

# --- Lapis 2: Akun login aplikasi (mutation login) ---
ADMIN: <email-admin>
PASSWORD_ADMIN: <password-admin>

# Data perusahaan untuk mutation `login`
COMPANY_ID: <company-id>
COMPANY_SLUG: <company-slug>
COMPANY_NAME: <company-name>
